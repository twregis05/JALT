<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>JALT – Login</title>
    <link rel="stylesheet" href="css/styles.css" />
  </head>
  <body>
    <main id="login-page">
      <h1>Login</h1>
        <form action="/login" method="POST">
          <fieldset class="login-fieldset">
              <label>Email: <input class="login-email" type="email" name="email" required></label> <br>
              <label>Password: <input class="login-password" type="password" name="password" required></label> <br>
              <div class="login-buttons">
                  <input class="login-reset" type="reset">
                  <input class="login-submit" type="submit" value="Login">
              </div>
              <div class="loginlinks-container">
                  <a class="signup-link" href="/signup">Sign Up</a>
              </div>
          </fieldset>
        </form>
    </main>

    <script src="js/api.js"></script>
    <script src="js/login.js"></script>
  </body>
</html>
